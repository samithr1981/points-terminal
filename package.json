{
  "name": "points-terminal",
  "version": "0.3.0",
  "private": false,
  "description": "INR-first reward points optimizer for Indian credit card holders. 39 cards, 14 banks, 30 redemption partners.",
  "type": "module",
  "scripts": {
    "dev": "vite",
