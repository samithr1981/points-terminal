    "preview": "vite preview",
    "build:data": "node scripts/build-data.js",
    "validate:data": "node scripts/validate-data.js",
    "lint": "eslint src --ext js,jsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.383.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "js-yaml": "^4.1.0",
    "vite": "^5.4.11"
  },
  "keywords": [
    "credit-cards",
    "reward-points",
    "india",
    "fintech",
    "travel",
    "miles",
    "hdfc",
    "axis",
    "amex",
    "icici",
    "sbi"
  ],
